{
  "rules": [
    {
      "name": "Sääntö 1: GitHub issue opened → Luo Jira work item",
      "state": "ENABLED",
      "canOtherRuleTrigger": false,
      "notifyOnError": "FIRSTERROR",
      "trigger": {
        "component": "TRIGGER",
        "type": "jira.trigger.incoming.webhook",
        "value": {
          "webhookType": "NO_ISSUES"
        }
      },
      "components": [
        {
          "component": "ACTION",
          "type": "jira.lookup.issues",
          "value": {
            "query": {
              "jql": "project = US AND cf[10072] = {{webhookData.issue.number}} AND cf[10071] = \"{{webhookData.repository.name}}\""
            },
            "variableName": "lookupIssues"
          }
        },
        {
          "component": "CONDITION",
          "type": "jira.condition.if",
          "value": {
            "conditions": [
              {
                "first": "{{lookupIssues.size}}",
                "operator": "EQUALS",
                "second": "0"
              }
            ],
            "operator": "AND"
          }
        },
        {
          "component": "ACTION",
          "type": "jira.issue.create",
          "value": {
            "project": "US",
            "issuetype": "Story",
            "fields": {
              "summary": "Git: {{webhookData.issue.title}}",
              "description": "{{webhookData.issue.body}}",
              "customfield_10071": "{{webhookData.repository.name}}",
              "customfield_10072": "{{webhookData.issue.number}}",
              "customfield_10073": "{{webhookData.issue.html_url}}"
            }
          }
        }
      ]
    },
    {
      "name": "Sääntö 2: GitHub issue edited → Päivitä Jira work item",
      "state": "ENABLED",
      "canOtherRuleTrigger": false,
      "notifyOnError": "FIRSTERROR",
      "trigger": {
        "component": "TRIGGER",
        "type": "jira.trigger.incoming.webhook",
        "value": {
          "webhookType": "NO_ISSUES"
        }
      },
      "components": [
        {
          "component": "CONDITION",
          "type": "jira.condition.if",
          "value": {
            "conditions": [
              {
                "first": "{{webhookData.action}}",
                "operator": "EQUALS",
                "second": "edited"
              }
            ],
            "operator": "AND"
          }
        },
        {
          "component": "CONDITION",
          "type": "jira.condition.if",
          "value": {
            "conditions": [
              {
                "first": "{{webhookData.issue.title}}",
                "operator": "NOT_STARTS_WITH",
                "second": "Jira:"
              }
            ],
            "operator": "AND"
          }
        },
        {
          "component": "ACTION",
          "type": "jira.lookup.issues",
          "value": {
            "query": {
              "jql": "project = US AND cf[10072] = {{webhookData.issue.number}} AND cf[10071] = \"{{webhookData.repository.name}}\""
            },
            "variableName": "lookupIssues"
          }
        },
        {
          "component": "CONDITION",
          "type": "jira.condition.if",
          "value": {
            "conditions": [
              {
                "first": "{{lookupIssues.size}}",
                "operator": "GREATER_THAN",
                "second": "0"
              }
            ],
            "operator": "AND"
          }
        },
        {
          "component": "ACTION",
          "type": "jira.issue.edit",
          "value": {
            "issueKey": "{{lookupIssues.first.key}}",
            "fields": {
              "summary": "Git: {{webhookData.issue.title}}",
              "description": "{{webhookData.issue.body}}"
            }
          }
        }
      ]
    },
    {
      "name": "Sääntö 3: GitHub issue closed → Transition work item → Done",
      "state": "ENABLED",
      "canOtherRuleTrigger": false,
      "notifyOnError": "FIRSTERROR",
      "trigger": {
        "component": "TRIGGER",
        "type": "jira.trigger.incoming.webhook",
        "value": {
          "webhookType": "NO_ISSUES"
        }
      },
      "components": [
        {
          "component": "CONDITION",
          "type": "jira.condition.if",
          "value": {
            "conditions": [
              {
                "first": "{{webhookData.action}}",
                "operator": "EQUALS",
                "second": "closed"
              }
            ],
            "operator": "AND"
          }
        },
        {
          "component": "ACTION",
          "type": "jira.lookup.issues",
          "value": {
            "query": {
              "jql": "project = US AND cf[10072] = {{webhookData.issue.number}} AND cf[10071] = \"{{webhookData.repository.name}}\""
            },
            "variableName": "lookupIssues"
          }
        },
        {
          "component": "CONDITION",
          "type": "jira.condition.if",
          "value": {
            "conditions": [
              {
                "first": "{{lookupIssues.size}}",
                "operator": "GREATER_THAN",
                "second": "0"
              }
            ],
            "operator": "AND"
          }
        },
        {
          "component": "ACTION",
          "type": "jira.issue.transition",
          "value": {
            "issueKey": "{{lookupIssues.first.key}}",
            "to": "Done"
          }
        },
        {
          "component": "ACTION",
          "type": "jira.issue.edit",
          "value": {
            "issueKey": "{{lookupIssues.first.key}}",
            "fields": {
              "resolution": "{{#if webhookData.issue.state_reason == 'completed'}}Fixed{{else if webhookData.issue.state_reason == 'not_planned'}}Won't Do{{else if webhookData.issue.state_reason == 'duplicate'}}Duplicate{{else}}Fixed{{/if}}"
            }
          }
        }
      ]
    },
    {
      "name": "Sääntö 4: GitHub issue reopened → Transition work item → To Do",
      "state": "ENABLED",
      "canOtherRuleTrigger": false,
      "notifyOnError": "FIRSTERROR",
      "trigger": {
        "component": "TRIGGER",
        "type": "jira.trigger.incoming.webhook",
        "value": {
          "webhookType": "NO_ISSUES"
        }
      },
      "components": [
        {
          "component": "CONDITION",
          "type": "jira.condition.if",
          "value": {
            "conditions": [
              {
                "first": "{{webhookData.action}}",
                "operator": "EQUALS",
                "second": "reopened"
              }
            ],
            "operator": "AND"
          }
        },
        {
          "component": "ACTION",
          "type": "jira.lookup.issues",
          "value": {
            "query": {
              "jql": "project = US AND cf[10072] = {{webhookData.issue.number}} AND cf[10071] = \"{{webhookData.repository.name}}\""
            },
            "variableName": "lookupIssues"
          }
        },
        {
          "component": "CONDITION",
          "type": "jira.condition.if",
          "value": {
            "conditions": [
              {
                "first": "{{lookupIssues.size}}",
                "operator": "GREATER_THAN",
                "second": "0"
              }
            ],
            "operator": "AND"
          }
        },
        {
          "component": "ACTION",
          "type": "jira.issue.edit",
          "value": {
            "issueKey": "{{lookupIssues.first.key}}",
            "fields": {
              "resolution": null
            }
          }
        },
        {
          "component": "ACTION",
          "type": "jira.issue.transition",
          "value": {
            "issueKey": "{{lookupIssues.first.key}}",
            "to": "To Do"
          }
        }
      ]
    },
    {
      "name": "Sääntö 5: GitHub issue labeled/unlabeled → Edit work item labels",
      "state": "ENABLED",
      "canOtherRuleTrigger": false,
      "notifyOnError": "FIRSTERROR",
      "trigger": {
        "component": "TRIGGER",
        "type": "jira.trigger.incoming.webhook",
        "value": {
          "webhookType": "NO_ISSUES"
        }
      },
      "components": [
        {
          "component": "CONDITION",
          "type": "jira.condition.if",
          "value": {
            "conditions": [
              {
                "first": "{{webhookData.action}}",
                "operator": "IN",
                "second": "labeled,unlabeled"
              }
            ],
            "operator": "AND"
          }
        },
        {
          "component": "ACTION",
          "type": "jira.lookup.issues",
          "value": {
            "query": {
              "jql": "project = US AND cf[10072] = {{webhookData.issue.number}} AND cf[10071] = \"{{webhookData.repository.name}}\""
            },
            "variableName": "lookupIssues"
          }
        },
        {
          "component": "CONDITION",
          "type": "jira.condition.if",
          "value": {
            "conditions": [
              {
                "first": "{{lookupIssues.size}}",
                "operator": "GREATER_THAN",
                "second": "0"
              }
            ],
            "operator": "AND"
          }
        },
        {
          "component": "ACTION",
          "type": "jira.issue.edit",
          "value": {
            "issueKey": "{{lookupIssues.first.key}}",
            "fields": {
              "labels": {
                "operation": "{{#if webhookData.action == 'labeled'}}add{{else}}remove{{/if}}",
                "value": "{{webhookData.label.name}}"
              }
            }
          }
        },
        {
          "component": "CONDITION",
          "type": "jira.condition.if",
          "value": {
            "conditions": [
              {
                "first": "{{webhookData.label.name}}",
                "operator": "STARTS_WITH",
                "second": "priority:"
              }
            ],
            "operator": "AND"
          }
        },
        {
          "component": "ACTION",
          "type": "jira.issue.edit",
          "value": {
            "issueKey": "{{lookupIssues.first.key}}",
            "fields": {
              "priority": {
                "name": "{{#if webhookData.label.name == 'priority:high'}}High{{else if webhookData.label.name == 'priority:medium'}}Medium{{else if webhookData.label.name == 'priority:low'}}Low{{else if webhookData.label.name == 'priority:lowest'}}Lowest{{/if}}"
              }
            }
          }
        }
      ]
    },
    {
      "name": "Sääntö 7: GitHub issue milestoned/demilestoned → Päivitä fixVersions",
      "state": "DISABLED",
      "canOtherRuleTrigger": false,
      "notifyOnError": "FIRSTERROR",
      "_comment": "Tila: Suunniteltu, ei toteutettu. projectId haetaan kerran: GET /rest/api/3/project/US → kenttä id.",
      "trigger": {
        "component": "TRIGGER",
        "type": "jira.trigger.incoming.webhook",
        "value": {
          "webhookType": "NO_ISSUES"
        }
      },
      "components": [
        {
          "component": "CONDITION",
          "type": "jira.condition.if",
          "value": {
            "conditions": [
              {
                "first": "{{webhookData.action}}",
                "operator": "IN",
                "second": "milestoned,demilestoned"
              }
            ],
            "operator": "AND"
          }
        },
        {
          "component": "ACTION",
          "type": "jira.lookup.issues",
          "value": {
            "query": {
              "jql": "project = US AND cf[10072] = {{webhookData.issue.number}} AND cf[10071] = \"{{webhookData.repository.name}}\""
            },
            "variableName": "lookupIssues"
          }
        },
        {
          "component": "CONDITION",
          "type": "jira.condition.if",
          "value": {
            "conditions": [
              {
                "first": "{{lookupIssues.size}}",
                "operator": "GREATER_THAN",
                "second": "0"
              }
            ],
            "operator": "AND"
          }
        },
        {
          "component": "ACTION",
          "type": "jira.issue.edit",
          "value": {
            "issueKey": "{{lookupIssues.first.key}}",
            "fields": {
              "fixVersions": "{{webhookData.issue.milestone.title}}"
            }
          }
        },
        {
          "component": "ACTION",
          "type": "jira.util.send.web.request",
          "value": {
            "method": "POST",
            "url": "https://uutisseuranta.atlassian.net/rest/api/3/version",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "name": "{{webhookData.issue.milestone.title}}",
              "releaseDate": "{{webhookData.issue.milestone.due_on}}",
              "projectId": "<HAETTAVA: GET /rest/api/3/project/US → id>"
            }
          }
        }
      ]
    },
    {
      "name": "Sääntö 8: GitHub issue comment created → Comment on work item",
      "state": "ENABLED",
      "canOtherRuleTrigger": false,
      "notifyOnError": "FIRSTERROR",
      "trigger": {
        "component": "TRIGGER",
        "type": "jira.trigger.incoming.webhook",
        "value": {
          "webhookType": "NO_ISSUES"
        }
      },
      "components": [
        {
          "component": "CONDITION",
          "type": "jira.condition.if",
          "value": {
            "conditions": [
              {
                "first": "{{webhookData.action}}",
                "operator": "EQUALS",
                "second": "created"
              }
            ],
            "operator": "AND"
          }
        },
        {
          "component": "ACTION",
          "type": "jira.lookup.issues",
          "value": {
            "query": {
              "jql": "project = US AND cf[10072] = {{webhookData.issue.number}} AND cf[10071] = \"{{webhookData.repository.name}}\""
            },
            "variableName": "lookupIssues"
          }
        },
        {
          "component": "CONDITION",
          "type": "jira.condition.if",
          "value": {
            "conditions": [
              {
                "first": "{{lookupIssues.size}}",
                "operator": "GREATER_THAN",
                "second": "0"
              }
            ],
            "operator": "AND"
          }
        },
        {
          "component": "CONDITION",
          "type": "jira.condition.if",
          "value": {
            "conditions": [
              {
                "first": "{{webhookData.comment.body}}",
                "operator": "NOT_STARTS_WITH",
                "second": "Jira:"
              }
            ],
            "operator": "AND"
          }
        },
        {
          "component": "ACTION",
          "type": "jira.issue.comment",
          "value": {
            "issueKey": "{{lookupIssues.first.key}}",
            "comment": "Git: @{{webhookData.comment.user.login}}: {{webhookData.comment.body}}"
          }
        }
      ]
    },
    {
      "name": "Sääntö 9: Jira status muuttuu → Päivitä GitHub issue state",
      "state": "ENABLED",
      "canOtherRuleTrigger": false,
      "notifyOnError": "FIRSTERROR",
      "_comment": "Tila: Tuotannossa. Silmukkaesto: GitHub-puoli skipaa [Jira]-etuliitteellä alkavat kommentit (D-002). Label-poistologiikka poistettu (L-006).",
      "trigger": {
        "component": "TRIGGER",
        "type": "jira.trigger.issue.transitioned",
        "value": {}
      },
      "components": [
        {
          "component": "CONDITION",
          "type": "jira.condition.if",
          "value": {
            "conditions": [
              {
                "first": "{{issue.customfield_10072}}",
                "operator": "IS_NOT_EMPTY"
              }
            ],
            "operator": "AND"
          }
        },
        {
          "component": "CONDITION",
          "type": "jira.condition.if",
          "_comment": "Sulkee GitHub-issuen kun Jira-status on Done; avaa uudelleen muilla transitioilla.",
          "value": {
            "conditions": [
              {
                "first": "{{issue.status.name}}",
                "operator": "IN",
                "second": "Done,In Progress,To Do,In Review"
              }
            ],
            "operator": "AND"
          }
        },
        {
          "component": "ACTION",
          "type": "jira.util.send.web.request",
          "_comment": "PATCH GitHub issue state: Done → closed (completed), muut → open. Silmukkaesto: tämä ei triggeröi Sääntöä 1 koska GitHub-issue-eventit ovat eri webhook-kanava kuin Jira-automation.",
          "value": {
            "method": "PATCH",
            "url": "https://api.github.com/repos/uutisseuranta/{{issue.customfield_10071}}/issues/{{issue.customfield_10072}}",
            "headers": {
              "Authorization": "Bearer {{secrets.GITHUB_TOKEN}}",
              "Content-Type": "application/json"
            },
            "body": {
              "state": "{{#if issue.status.name == 'Done'}}closed{{else}}open{{/if}}",
              "state_reason": "{{#if issue.status.name == 'Done'}}completed{{/if}}"
            }
          }
        }
      ]
    },
    {
      "name": "Sääntö 12: Jira sprint muuttuu → Päivitä GitHub label",
      "state": "DISABLED",
      "canOtherRuleTrigger": false,
      "notifyOnError": "FIRSTERROR",
      "_comment": "Tila: Suunniteltu (TODO). Label-poistologiikka poistettu (L-006).",
      "trigger": {
        "component": "TRIGGER",
        "type": "jira.trigger.field.changed",
        "value": {
          "fields": [
            "sprint"
          ]
        }
      },
      "components": [
        {
          "component": "CONDITION",
          "type": "jira.condition.if",
          "value": {
            "conditions": [
              {
                "first": "{{issue.customfield_10072}}",
                "operator": "IS_NOT_EMPTY"
              }
            ],
            "operator": "AND"
          }
        },
        {
          "component": "ACTION",
          "type": "jira.util.send.web.request",
          "value": {
            "method": "POST",
            "url": "https://api.github.com/repos/uutisseuranta/{{issue.customfield_10071}}/issues/{{issue.customfield_10072}}/labels",
            "headers": {
              "Authorization": "Bearer {{secrets.GITHUB_TOKEN}}",
              "Content-Type": "application/json"
            },
            "body": {
              "labels": [
                "sprint:{{issue.sprint.name}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Sääntö 13: Jira summary muuttuu → Päivitä GitHub title",
      "state": "DISABLED",
      "canOtherRuleTrigger": false,
      "notifyOnError": "FIRSTERROR",
      "_comment": "Tila: Suunniteltu (TODO). Silmukkaesto: skipataan jos summary alkaa [GitHub] — se on Sääntö 2:n kirjoittama.",
      "trigger": {
        "component": "TRIGGER",
        "type": "jira.trigger.field.changed",
        "value": {
          "fields": [
            "summary"
          ]
        }
      },
      "components": [
        {
          "component": "CONDITION",
          "type": "jira.condition.if",
          "value": {
            "conditions": [
              {
                "first": "{{issue.customfield_10072}}",
                "operator": "IS_NOT_EMPTY"
              }
            ],
            "operator": "AND"
          }
        },
        {
          "component": "CONDITION",
          "type": "jira.condition.if",
          "value": {
            "conditions": [
              {
                "first": "{{issue.summary}}",
                "operator": "NOT_STARTS_WITH",
                "second": "Git:"
              }
            ],
            "operator": "AND"
          }
        },
        {
          "component": "ACTION",
          "type": "jira.util.send.web.request",
          "value": {
            "method": "PATCH",
            "url": "https://api.github.com/repos/uutisseuranta/{{issue.customfield_10071}}/issues/{{issue.customfield_10072}}",
            "headers": {
              "Authorization": "Bearer {{secrets.GITHUB_TOKEN}}",
              "Content-Type": "application/json"
            },
            "body": {
              "title": "Jira: {{issue.summary}}"
            }
          }
        }
      ]
    },
    {
      "name": "Sääntö 14: Uusi Jira kommentti → Lisää GitHub issue comment",
      "state": "DISABLED",
      "canOtherRuleTrigger": false,
      "notifyOnError": "FIRSTERROR",
      "_comment": "Tila: Suunniteltu (TODO). Silmukkaesto: skipataan jos kommentti alkaa Git: — se on Sääntö 8:n kirjoittama.",
      "trigger": {
        "component": "TRIGGER",
        "type": "jira.trigger.comment.added",
        "value": {}
      },
      "components": [
        {
          "component": "CONDITION",
          "type": "jira.condition.if",
          "value": {
            "conditions": [
              {
                "first": "{{issue.customfield_10072}}",
                "operator": "IS_NOT_EMPTY"
              }
            ],
            "operator": "AND"
          }
        },
        {
          "component": "CONDITION",
          "type": "jira.condition.if",
          "value": {
            "conditions": [
              {
                "first": "{{comment.body}}",
                "operator": "NOT_STARTS_WITH",
                "second": "Git:"
              }
            ],
            "operator": "AND"
          }
        },
        {
          "component": "ACTION",
          "type": "jira.util.send.web.request",
          "value": {
            "method": "POST",
            "url": "https://api.github.com/repos/uutisseuranta/{{issue.customfield_10071}}/issues/{{issue.customfield_10072}}/comments",
            "headers": {
              "Authorization": "Bearer {{secrets.GITHUB_TOKEN}}",
              "Content-Type": "application/json"
            },
            "body": {
              "body": "Jira: {{comment.author.displayName}}: {{comment.body}}"
            }
          }
        }
      ]
    },
    {
      "name": "Sääntö 15: fixVersions muuttuu → Päivitä GitHub milestone",
      "state": "DISABLED",
      "canOtherRuleTrigger": false,
      "notifyOnError": "FIRSTERROR",
      "_comment": "Tila: Suunniteltu (TODO). Milestoneja hallitaan vain GitHub-vetoisesti (L-009), joten sääntö ainoastaan hakee numeron GET-pyynnöllä ja tekee PATCH-päivityksen issuelle.",
      "trigger": {
        "component": "TRIGGER",
        "type": "jira.trigger.field.changed",
        "value": {
          "fields": [
            "fixVersions"
          ]
        }
      },
      "components": [
        {
          "component": "CONDITION",
          "type": "jira.condition.if",
          "value": {
            "conditions": [
              {
                "first": "{{issue.customfield_10072}}",
                "operator": "IS_NOT_EMPTY"
              }
            ],
            "operator": "AND"
          }
        },
        {
          "component": "ACTION",
          "type": "jira.util.send.web.request",
          "value": {
            "method": "GET",
            "url": "https://api.github.com/repos/uutisseuranta/{{issue.customfield_10071}}/milestones",
            "headers": {
              "Authorization": "Bearer {{secrets.GITHUB_TOKEN}}",
              "Content-Type": "application/json"
            }
          }
        },
        {
          "component": "ACTION",
          "type": "jira.util.send.web.request",
          "value": {
            "method": "PATCH",
            "url": "https://api.github.com/repos/uutisseuranta/{{issue.customfield_10071}}/issues/{{issue.customfield_10072}}",
            "headers": {
              "Authorization": "Bearer {{secrets.GITHUB_TOKEN}}",
              "Content-Type": "application/json"
            },
            "body": {
              "milestone": "{{webhookResponse.body.find(x => x.title == issue.fixVersions.first.name).number}}"
            }
          }
        }
      ]
    }
  ]
}
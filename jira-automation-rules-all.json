{
  "cloud": true,
  "rules": [
    {
      "name": "Sääntö 1: GitHub issue opened → Luo Jira work item",
      "state": "ENABLED",
      "canOtherRuleTrigger": false,
      "notifyOnError": "FIRSTERROR",
      "trigger": {
        "component": "TRIGGER",
        "type": "jira.incoming.webhook",
        "value": {
          "webhookType": "NO_ISSUES"
        }
      },
      "components": [
        {
          "component": "ACTION",
          "type": "jira.lookup.issues",
          "value": {
            "query": {
              "jql": "project = US AND cf[10072] = {{webhookData.issue.number}} AND cf[10071] = \"{{webhookData.repository.name}}\""
            },
            "variableName": "lookupIssues"
          }
        },
        {
          "component": "CONDITION",
          "type": "jira.condition.container.block",
          "value": null,
          "children": [
            {
              "component": "CONDITION_BLOCK",
              "type": "jira.condition.if.block",
              "value": {
                "conditionMatchType": "ALL"
              },
              "children": [
                {
                  "component": "CONDITION",
                  "type": "jira.comparator.condition",
                  "value": {
                    "first": "{{lookupIssues.size}}",
                    "operator": "EQUALS",
                    "second": "0"
                  }
                },
                {
                  "component": "ACTION",
                  "type": "jira.issue.create",
                  "value": {
                    "project": "US",
                    "issuetype": "Story",
                    "fields": {
                      "summary": "Git: {{webhookData.issue.title}}",
                      "description": "{{webhookData.issue.body}}",
                      "customfield_10071": "{{webhookData.repository.name}}",
                      "customfield_10072": "{{webhookData.issue.number}}",
                      "customfield_10073": "{{webhookData.issue.html_url}}"
                    }
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Sääntö 2: GitHub issue edited → Päivitä Jira work item",
      "state": "ENABLED",
      "canOtherRuleTrigger": false,
      "notifyOnError": "FIRSTERROR",
      "trigger": {
        "component": "TRIGGER",
        "type": "jira.incoming.webhook",
        "value": {
          "webhookType": "NO_ISSUES"
        }
      },
      "components": [
        {
          "component": "CONDITION",
          "type": "jira.condition.container.block",
          "value": null,
          "children": [
            {
              "component": "CONDITION_BLOCK",
              "type": "jira.condition.if.block",
              "value": {
                "conditionMatchType": "ALL"
              },
              "children": [
                {
                  "component": "CONDITION",
                  "type": "jira.comparator.condition",
                  "value": {
                    "first": "{{webhookData.action}}",
                    "operator": "EQUALS",
                    "second": "edited"
                  }
                },
                {
                  "component": "CONDITION",
                  "type": "jira.condition.container.block",
                  "value": null,
                  "children": [
                    {
                      "component": "CONDITION_BLOCK",
                      "type": "jira.condition.if.block",
                      "value": {
                        "conditionMatchType": "ALL"
                      },
                      "children": [
                        {
                          "component": "CONDITION",
                          "type": "jira.comparator.condition",
                          "value": {
                            "first": "{{webhookData.issue.title}}",
                            "operator": "REGEX_NOT_MATCHES",
                            "second": "^Jira:"
                          }
                        },
                        {
                          "component": "ACTION",
                          "type": "jira.lookup.issues",
                          "value": {
                            "query": {
                              "jql": "project = US AND cf[10072] = {{webhookData.issue.number}} AND cf[10071] = \"{{webhookData.repository.name}}\""
                            },
                            "variableName": "lookupIssues"
                          }
                        },
                        {
                          "component": "CONDITION",
                          "type": "jira.condition.container.block",
                          "value": null,
                          "children": [
                            {
                              "component": "CONDITION_BLOCK",
                              "type": "jira.condition.if.block",
                              "value": {
                                "conditionMatchType": "ALL"
                              },
                              "children": [
                                {
                                  "component": "CONDITION",
                                  "type": "jira.comparator.condition",
                                  "value": {
                                    "first": "{{lookupIssues.size}}",
                                    "operator": "GREATER_THAN",
                                    "second": "0"
                                  }
                                },
                                {
                                  "component": "ACTION",
                                  "type": "jira.issue.edit",
                                  "value": {
                                    "issueKey": "{{lookupIssues.first.key}}",
                                    "fields": {
                                      "summary": "Git: {{webhookData.issue.title}}",
                                      "description": "{{webhookData.issue.body}}"
                                    }
                                  }
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Sääntö 3: GitHub issue closed → Transition work item → Done",
      "state": "ENABLED",
      "canOtherRuleTrigger": false,
      "notifyOnError": "FIRSTERROR",
      "trigger": {
        "component": "TRIGGER",
        "type": "jira.incoming.webhook",
        "value": {
          "webhookType": "NO_ISSUES"
        }
      },
      "components": [
        {
          "component": "CONDITION",
          "type": "jira.condition.container.block",
          "value": null,
          "children": [
            {
              "component": "CONDITION_BLOCK",
              "type": "jira.condition.if.block",
              "value": {
                "conditionMatchType": "ALL"
              },
              "children": [
                {
                  "component": "CONDITION",
                  "type": "jira.comparator.condition",
                  "value": {
                    "first": "{{webhookData.action}}",
                    "operator": "EQUALS",
                    "second": "closed"
                  }
                },
                {
                  "component": "ACTION",
                  "type": "jira.lookup.issues",
                  "value": {
                    "query": {
                      "jql": "project = US AND cf[10072] = {{webhookData.issue.number}} AND cf[10071] = \"{{webhookData.repository.name}}\""
                    },
                    "variableName": "lookupIssues"
                  }
                },
                {
                  "component": "CONDITION",
                  "type": "jira.condition.container.block",
                  "value": null,
                  "children": [
                    {
                      "component": "CONDITION_BLOCK",
                      "type": "jira.condition.if.block",
                      "value": {
                        "conditionMatchType": "ALL"
                      },
                      "children": [
                        {
                          "component": "CONDITION",
                          "type": "jira.comparator.condition",
                          "value": {
                            "first": "{{lookupIssues.size}}",
                            "operator": "GREATER_THAN",
                            "second": "0"
                          }
                        },
                        {
                          "component": "ACTION",
                          "type": "jira.issue.transition",
                          "value": {
                            "issueKey": "{{lookupIssues.first.key}}",
                            "to": "Done"
                          }
                        },
                        {
                          "component": "ACTION",
                          "type": "jira.issue.edit",
                          "value": {
                            "issueKey": "{{lookupIssues.first.key}}",
                            "fields": {
                              "resolution": "{{#if webhookData.issue.state_reason == 'completed'}}Fixed{{else if webhookData.issue.state_reason == 'not_planned'}}Won't Do{{else if webhookData.issue.state_reason == 'duplicate'}}Duplicate{{else}}Fixed{{/if}}"
                            }
                          }
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {

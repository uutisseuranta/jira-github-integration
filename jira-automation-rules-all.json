      ]
    },
    {
      "name": "Sääntö 5: GitHub issue labeled/unlabeled → Edit work item labels",
      "state": "ENABLED",
      "canOtherRuleTrigger": false,
      "notifyOnError": "FIRSTERROR",
      "trigger": {
        "component": "TRIGGER",
        "type": "jira.incoming.webhook",
        "value": {
          "webhookType": "NO_ISSUES"
        }
      },
      "components": [
        {
          "component": "CONDITION",
          "type": "jira.condition.container.block",
          "value": null,
          "children": [
            {
              "component": "CONDITION_BLOCK",
              "type": "jira.condition.if.block",
              "value": {
                "conditionMatchType": "ALL"
              },
              "children": [
                {
                  "component": "CONDITION",
                  "type": "jira.comparator.condition",
                  "value": {
                    "first": "{{webhookData.action}}",
                    "operator": "REGEX_MATCHES",
                    "second": "^(labeled|unlabeled)$"
                  }
                },
                {
                  "component": "ACTION",
                  "type": "jira.lookup.issues",
                  "value": {
                    "query": {
                      "jql": "project = US AND cf[10072] = {{webhookData.issue.number}} AND cf[10071] = \"{{webhookData.repository.name}}\""
                    },
                    "variableName": "lookupIssues"
                  }
                },
                {
                  "component": "CONDITION",
                  "type": "jira.condition.container.block",
                  "value": null,
                  "children": [
                    {
                      "component": "CONDITION_BLOCK",
                      "type": "jira.condition.if.block",
                      "value": {
                        "conditionMatchType": "ALL"
                      },
                      "children": [
                        {
                          "component": "CONDITION",
                          "type": "jira.comparator.condition",
                          "value": {
                            "first": "{{lookupIssues.size}}",
                            "operator": "GREATER_THAN",
                            "second": "0"
                          }
                        },
                        {
                          "component": "ACTION",
                          "type": "jira.issue.edit",
                          "value": {
                            "issueKey": "{{lookupIssues.first.key}}",
                            "fields": {
                              "labels": {
                                "operation": "{{#if webhookData.action == 'labeled'}}add{{else}}remove{{/if}}",
                                "value": "{{webhookData.label.name}}"
                              }
                            }
                          }
                        },
                        {
                          "component": "CONDITION",
                          "type": "jira.condition.container.block",
                          "value": null,
                          "children": [
                            {
                              "component": "CONDITION_BLOCK",
                              "type": "jira.condition.if.block",
                              "value": {
                                "conditionMatchType": "ALL"
                              },
                              "children": [
                                {
                                  "component": "CONDITION",
                                  "type": "jira.comparator.condition",
                                  "value": {
                                    "first": "{{webhookData.label.name}}",
                                    "operator": "STARTS_WITH",
                                    "second": "priority:"
                                  }
                                },
                                {
                                  "component": "ACTION",
                                  "type": "jira.issue.edit",
                                  "value": {
                                    "issueKey": "{{lookupIssues.first.key}}",
                                    "fields": {
                                      "priority": {
                                        "name": "{{#if webhookData.label.name == 'priority:high'}}High{{else if webhookData.label.name == 'priority:medium'}}Medium{{else if webhookData.label.name == 'priority:low'}}Low{{else if webhookData.label.name == 'priority:lowest'}}Lowest{{/if}}"
                                      }
                                    }
                                  }
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Sääntö 7: GitHub issue milestoned/demilestoned → Päivitä fixVersions",
      "state": "DISABLED",
      "canOtherRuleTrigger": false,
      "notifyOnError": "FIRSTERROR",
      "_comment": "Tila: Suunniteltu, ei toteutettu. projectId haetaan kerran: GET /rest/api/3/project/US → kenttä id.",
      "trigger": {
        "component": "TRIGGER",
        "type": "jira.incoming.webhook",
        "value": {
          "webhookType": "NO_ISSUES"
        }
      },
      "components": [
        {
          "component": "CONDITION",
          "type": "jira.condition.container.block",
          "value": null,
          "children": [
            {
              "component": "CONDITION_BLOCK",
              "type": "jira.condition.if.block",
              "value": {
                "conditionMatchType": "ALL"
              },
              "children": [
                {
                  "component": "CONDITION",
                  "type": "jira.comparator.condition",
                  "value": {
                    "first": "{{webhookData.action}}",
                    "operator": "REGEX_MATCHES",
                    "second": "^(milestoned|demilestoned)$"
                  }
                },
                {
                  "component": "ACTION",
                  "type": "jira.lookup.issues",
                  "value": {
                    "query": {
                      "jql": "project = US AND cf[10072] = {{webhookData.issue.number}} AND cf[10071] = \"{{webhookData.repository.name}}\""
                    },
                    "variableName": "lookupIssues"
                  }
                },
                {
                  "component": "CONDITION",
                  "type": "jira.condition.container.block",
                  "value": null,
                  "children": [
                    {
                      "component": "CONDITION_BLOCK",
                      "type": "jira.condition.if.block",
                      "value": {
                        "conditionMatchType": "ALL"
                      },
                      "children": [
                        {
                          "component": "CONDITION",
                          "type": "jira.comparator.condition",
                          "value": {
                            "first": "{{lookupIssues.size}}",
                            "operator": "GREATER_THAN",
                            "second": "0"
                          }
                        },
                        {
                          "component": "ACTION",
                          "type": "jira.issue.edit",
                          "value": {
                            "issueKey": "{{lookupIssues.first.key}}",
                            "fields": {
                              "fixVersions": "{{webhookData.issue.milestone.title}}"
                            }
                          }
                        },
                        {
                          "component": "ACTION",
                          "type": "jira.web.request",
                          "value": {
                            "method": "POST",
                            "url": "https://uutisseuranta.atlassian.net/rest/api/3/version",
                            "headers": {
                              "Content-Type": "application/json"
                            },
                            "body": {
                              "name": "{{webhookData.issue.milestone.title}}",
                              "releaseDate": "{{webhookData.issue.milestone.due_on}}",
                              "projectId": "<HAETTAVA: GET /rest/api/3/project/US → id>"
                            }
                          }
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Sääntö 8: GitHub issue comment created → Comment on work item",
      "state": "ENABLED",
      "canOtherRuleTrigger": false,
      "notifyOnError": "FIRSTERROR",
      "trigger": {
        "component": "TRIGGER",
        "type": "jira.incoming.webhook",
        "value": {
          "webhookType": "NO_ISSUES"
        }
      },
      "components": [
        {
          "component": "CONDITION",
          "type": "jira.condition.container.block",
          "value": null,
          "children": [
            {
              "component": "CONDITION_BLOCK",
              "type": "jira.condition.if.block",
              "value": {
                "conditionMatchType": "ALL"
              },
              "children": [
                {
                  "component": "CONDITION",
                  "type": "jira.comparator.condition",
                  "value": {
                    "first": "{{webhookData.action}}",
                    "operator": "EQUALS",
                    "second": "created"
                  }
                },
                {
                  "component": "ACTION",
                  "type": "jira.lookup.issues",
                  "value": {
                    "query": {
                      "jql": "project = US AND cf[10072] = {{webhookData.issue.number}} AND cf[10071] = \"{{webhookData.repository.name}}\""
                    },
                    "variableName": "lookupIssues"
                  }
                },
                {
                  "component": "CONDITION",
                  "type": "jira.condition.container.block",
                  "value": null,
                  "children": [
                    {
                      "component": "CONDITION_BLOCK",
                      "type": "jira.condition.if.block",
                      "value": {
                        "conditionMatchType": "ALL"
                      },
                      "children": [
                        {
                          "component": "CONDITION",
                          "type": "jira.comparator.condition",
                          "value": {
                            "first": "{{lookupIssues.size}}",
                            "operator": "GREATER_THAN",
                            "second": "0"
                          }
                        },
                        {
                          "component": "CONDITION",
                          "type": "jira.condition.container.block",
                          "value": null,
                          "children": [
                            {
                              "component": "CONDITION_BLOCK",
                              "type": "jira.condition.if.block",
                              "value": {
                                "conditionMatchType": "ALL"
                              },
                              "children": [
                                {
                                  "component": "CONDITION",
                                  "type": "jira.comparator.condition",
                                  "value": {
                                    "first": "{{webhookData.comment.body}}",
                                    "operator": "REGEX_NOT_MATCHES",
                                    "second": "^Jira:"
                                  }
                                },
                                {
                                  "component": "ACTION",
                                  "type": "jira.issue.comment",
                                  "value": {
                                    "issueKey": "{{lookupIssues.first.key}}",
                                    "comment": "Git: @{{webhookData.comment.user.login}}: {{webhookData.comment.body}}"
                                  }
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Sääntö 9: Jira status muuttuu → Päivitä GitHub issue state",
      "state": "ENABLED",
      "canOtherRuleTrigger": false,
      "notifyOnError": "FIRSTERROR",
      "_comment": "Tila: Tuotannossa. Silmukkaesto: GitHub-puoli skipaa [Jira]-etuliitteellä alkavat kommentit (D-002). Label-poistologiikka poistettu (L-006).",
      "trigger": {
        "component": "TRIGGER",
        "type": "jira.issue.transitioned",
        "value": {}
      },
      "components": [
        {
          "component": "CONDITION",
          "type": "jira.condition.container.block",
          "value": null,
          "children": [
            {
              "component": "CONDITION_BLOCK",
              "type": "jira.condition.if.block",
              "value": {
                "conditionMatchType": "ALL"
              },
              "children": [
                {
                  "component": "CONDITION",
                  "type": "jira.comparator.condition",
                  "value": {
                    "first": "{{issue.customfield_10072}}",
                    "operator": "IS_NOT_EMPTY"
                  }
                },
                {
                  "component": "CONDITION",
                  "type": "jira.condition.container.block",
                  "value": null,
                  "children": [
                    {
                      "component": "CONDITION_BLOCK",
                      "type": "jira.condition.if.block",
                      "value": {
                        "conditionMatchType": "ALL"
                      },
                      "children": [
                        {
                          "component": "CONDITION",
                          "type": "jira.comparator.condition",
                          "value": {
                            "first": "{{issue.status.name}}",
                            "operator": "REGEX_MATCHES",
                            "second": "^(Done|In Progress|To Do|In Review)$"
                          }
                        },
                        {
                          "component": "ACTION",
                          "type": "jira.web.request",
                          "_comment": "PATCH GitHub issue state: Done → closed (completed), muut → open. Silmukkaesto: tämä ei triggeröi Sääntöä 1 koska GitHub-issue-eventit ovat eri webhook-kanava kuin Jira-automation.",
                          "value": {
                            "method": "PATCH",
                            "url": "https://api.github.com/repos/uutisseuranta/{{issue.customfield_10071}}/issues/{{issue.customfield_10072}}",
                            "headers": {
                              "Authorization": "Bearer {{secrets.GITHUB_TOKEN}}",
                              "Content-Type": "application/json"
                            },
                            "body": {
                              "state": "{{#if issue.status.name == 'Done'}}closed{{else}}open{{/if}}",
                              "state_reason": "{{#if issue.status.name == 'Done'}}completed{{/if}}"
                            }
                          }
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Sääntö 12: Jira sprint muuttuu → Päivitä GitHub label",
      "state": "DISABLED",
      "canOtherRuleTrigger": false,
      "notifyOnError": "FIRSTERROR",
      "_comment": "Tila: Suunniteltu (TODO). Label-poistologiikka poistettu (L-006).",
      "trigger": {
        "component": "TRIGGER",
        "type": "jira.field.changed",
        "value": {
          "fields": [
            "sprint"
          ]
        }
      },
      "components": [
        {
          "component": "CONDITION",
          "type": "jira.condition.container.block",
          "value": null,
          "children": [
            {
              "component": "CONDITION_BLOCK",
              "type": "jira.condition.if.block",
              "value": {
                "conditionMatchType": "ALL"
              },
              "children": [
                {
                  "component": "CONDITION",
                  "type": "jira.comparator.condition",
                  "value": {
                    "first": "{{issue.customfield_10072}}",
                    "operator": "IS_NOT_EMPTY"
                  }
                },
                {
                  "component": "ACTION",
                  "type": "jira.web.request",
                  "value": {
                    "method": "POST",
                    "url": "https://api.github.com/repos/uutisseuranta/{{issue.customfield_10071}}/issues/{{issue.customfield_10072}}/labels",
                    "headers": {
                      "Authorization": "Bearer {{secrets.GITHUB_TOKEN}}",
                      "Content-Type": "application/json"
                    },
                    "body": {
                      "labels": [
                        "sprint:{{issue.sprint.name}}"
                      ]
                    }
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Sääntö 13: Jira summary muuttuu → Päivitä GitHub title",
      "state": "DISABLED",

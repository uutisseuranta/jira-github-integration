{
  "name": "Sääntö 9: Jira status muuttuu → Päivitä GitHub issue state",
  "state": "ENABLED",
  "canOtherRuleTrigger": false,
  "notifyOnError": "FIRSTERROR",
  "_comment": "Tila: Tuotannossa. Silmukkaesto: GitHub-puoli skipaa [Jira]-etuliitteellä alkavat kommentit (D-002). Label-poistologiikka poistettu (L-006).",
  "trigger": {
    "component": "TRIGGER",
    "type": "jira.issue.transitioned",
    "value": {}
  },
  "components": [
    {
      "component": "CONDITION",
      "type": "jira.condition.container.block",
      "value": null,
      "children": [
        {
          "component": "CONDITION_BLOCK",
          "type": "jira.condition.if.block",
          "value": {
            "conditionMatchType": "ALL"
          },
          "children": [
            {
              "component": "CONDITION",
              "type": "jira.comparator.condition",
              "value": {
                "first": "{{issue.customfield_10072}}",
                "operator": "IS_NOT_EMPTY"
              }
            },
            {
              "component": "CONDITION",
              "type": "jira.condition.container.block",
              "value": null,
              "children": [
                {
                  "component": "CONDITION_BLOCK",
                  "type": "jira.condition.if.block",
                  "value": {
                    "conditionMatchType": "ALL"
                  },
                  "children": [
                    {
                      "component": "CONDITION",
                      "type": "jira.comparator.condition",
                      "value": {
                        "first": "{{issue.status.name}}",
                        "operator": "REGEX_MATCHES",
                        "second": "^(Done|In Progress|To Do|In Review)$"
                      }
                    },
                    {
                      "component": "ACTION",
                      "type": "jira.web.request",
                      "_comment": "PATCH GitHub issue state: Done → closed (completed), muut → open. Silmukkaesto: tämä ei triggeröi Sääntöä 1 koska GitHub-issue-eventit ovat eri webhook-kanava kuin Jira-automation.",
                      "value": {
                        "method": "PATCH",
                        "url": "https://api.github.com/repos/uutisseuranta/{{issue.customfield_10071}}/issues/{{issue.customfield_10072}}",
                        "headers": {
                          "Authorization": "Bearer {{secrets.GITHUB_TOKEN}}",
                          "Content-Type": "application/json"
                        },
                        "body": {
                          "state": "{{#if issue.status.name == 'Done'}}closed{{else}}open{{/if}}",
                          "state_reason": "{{#if issue.status.name == 'Done'}}completed{{/if}}"
                        }
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
{
  "name": "Sääntö 15: fixVersions muuttuu → Päivitä GitHub milestone",
  "state": "DISABLED",
  "canOtherRuleTrigger": false,
  "notifyOnError": "FIRSTERROR",
  "_comment": "Tila: Suunniteltu (TODO). Kaksi vaihetta: 1) hae milestone-numero GET-pyynnöllä, 2) päivitä tai luo.",
  "trigger": {
    "component": "TRIGGER",
    "type": "jira.trigger.field.changed",
    "value": {
      "fields": ["fixVersions"]
    }
  },
  "components": [
    {
      "component": "CONDITION",
      "type": "jira.condition.if",
      "value": {
        "conditions": [
          {
            "first": "{{issue.customfield_10072}}",
            "operator": "IS_NOT_EMPTY"
          }
        ],
        "operator": "AND"
      }
    },
    {
      "component": "ACTION",
      "type": "jira.util.send.web.request",
      "value": {
        "method": "GET",
        "url": "https://api.github.com/repos/uutisseuranta/{{issue.customfield_10071}}/milestones",
        "headers": {
          "Authorization": "Bearer {{secrets.GITHUB_TOKEN}}",
          "Content-Type": "application/json"
        }
      }
    },
    {
      "component": "ACTION",
      "type": "jira.util.send.web.request",
      "value": {
        "_comment": "Jos milestone löytyy nimellä: PATCH. Jos ei: POST /milestones.",
        "method": "POST",
        "url": "https://api.github.com/repos/uutisseuranta/{{issue.customfield_10071}}/milestones",
        "headers": {
          "Authorization": "Bearer {{secrets.GITHUB_TOKEN}}",
          "Content-Type": "application/json"
        },
        "body": {
          "title": "{{issue.fixVersions[0].name}}"
        }
      }
    }
  ]
}

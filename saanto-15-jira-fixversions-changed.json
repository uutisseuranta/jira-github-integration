{
  "name": "Sääntö 15: fixVersions muuttuu → Päivitä GitHub milestone",
  "state": "DISABLED",
  "canOtherRuleTrigger": false,
  "notifyOnError": "FIRSTERROR",
  "_comment": "Tila: Suunniteltu (TODO). Milestoneja hallitaan vain GitHub-vetoisesti (L-009), joten sääntö ainoastaan hakee numeron GET-pyynnöllä ja tekee PATCH-päivityksen issuelle.",
  "trigger": {
    "component": "TRIGGER",
    "type": "jira.trigger.field.changed",
    "value": {
      "fields": ["fixVersions"]
    }
  },
  "components": [
    {
      "component": "CONDITION",
      "type": "jira.condition.if",
      "value": {
        "conditions": [
          {
            "first": "{{issue.customfield_10072}}",
            "operator": "IS_NOT_EMPTY"
          }
        ],
        "operator": "AND"
      }
    },
    {
      "component": "ACTION",
      "type": "jira.util.send.web.request",
      "value": {
        "method": "GET",
        "url": "https://api.github.com/repos/uutisseuranta/{{issue.customfield_10071}}/milestones",
        "headers": {
          "Authorization": "Bearer {{secrets.GITHUB_TOKEN}}",
          "Content-Type": "application/json"
        }
      }
    },
    {
      "component": "ACTION",
      "type": "jira.util.send.web.request",
      "value": {
        "method": "PATCH",
        "url": "https://api.github.com/repos/uutisseuranta/{{issue.customfield_10071}}/issues/{{issue.customfield_10072}}",
        "headers": {
          "Authorization": "Bearer {{secrets.GITHUB_TOKEN}}",
          "Content-Type": "application/json"
        },
        "body": {
          "milestone": "{{webhookResponse.body.find(x => x.title == issue.fixVersions.first.name).number}}"
        }
      }
    }
  ]
}

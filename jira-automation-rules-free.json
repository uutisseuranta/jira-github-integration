{
  "cloud": true,
  "rules": [
    {
      "name": "Sääntö 1: GitHub issue opened → Luo Jira work item",
      "state": "ENABLED",
      "description": "Luo uuden Jira-tehtävän kun GitHubiin avataan issue",
      "trigger": {
        "component": "TRIGGER",
        "type": "jira.incoming.webhook",
        "value": {
          "searchOrProvide": "none",
          "jql": null
        }
      },
      "components": [
        {
          "component": "ACTION",
          "type": "jira.issue.create",
          "value": {
            "operations": [
              {
                "field": {
                  "type": "ID",
                  "value": "summary"
                },
                "fieldType": "summary",
                "type": "SET",
                "value": "Git: {{webhookData.issue.title}}"
              },
              {
                "field": {
                  "type": "ID",
                  "value": "description"
                },
                "fieldType": "description",
                "type": "SET",
                "value": "{{webhookData.issue.body}}"
              },
              {
                "field": {
                  "type": "ID",
                  "value": "project"
                },
                "fieldType": "project",
                "type": "SET",
                "value": {
                  "type": "ID",
                  "value": "10000"
                }
              },
              {
                "field": {
                  "type": "ID",
                  "value": "issuetype"
                },
                "fieldType": "issuetype",
                "type": "SET",
                "value": {
                  "type": "ID",
                  "value": "10040"
                }
              }
            ],
            "advancedFields": "{\n  \"fields\": {\n    \"customfield_10071\": \"{{webhookData.repository.name}}\",\n    \"customfield_10072\": {{webhookData.issue.number}},\n    \"customfield_10073\": \"{{webhookData.issue.html_url}}\"\n  }\n}",
            "sendNotifications": false
          }
        }
      ],
      "canOtherRuleTrigger": false,
      "notifyOnError": "FIRSTERROR",
      "projects": [],
      "labels": []
    },
    {
      "name": "Sääntö 2: GitHub issue edited → Päivitä Jira work item",
      "state": "ENABLED",
      "description": "Päivittää Jira-tehtävän otsikon ja kuvauksen kun GitHub-issuea muokataan",
      "trigger": {
        "component": "TRIGGER",
        "type": "jira.incoming.webhook",
        "value": {
          "searchOrProvide": "none",
          "jql": null
        }
      },
      "components": [
        {
          "component": "BRANCH",
          "type": "jira.issue.related",
          "value": {
            "relatedType": "jql",
            "jql": "project = US AND cf[10072] = {{webhookData.issue.number}} AND cf[10071] = \"{{webhookData.repository.name}}\"",
            "onlyUpdatedIssues": false
          },
          "children": [
            {
              "component": "ACTION",
              "type": "jira.issue.edit",
              "value": {
                "operations": [
                  {
                    "field": {
                      "type": "ID",
                      "value": "summary"
                    },
                    "fieldType": "summary",
                    "type": "SET",
                    "value": "Git: {{webhookData.issue.title}}"
                  },
                  {
                    "field": {
                      "type": "ID",
                      "value": "description"
                    },
                    "fieldType": "description",
                    "type": "SET",
                    "value": "{{webhookData.issue.body}}"
                  }
                ],
                "sendNotifications": false
              }
            }
          ]
        }
      ],
      "canOtherRuleTrigger": false,
      "notifyOnError": "FIRSTERROR",
      "projects": [],
      "labels": []
    },
    {
      "name": "Sääntö 3: GitHub issue closed → Transition work item → Done",
      "state": "ENABLED",
      "description": "Muuttaa Jira-tehtävän tilaksi Done kun GitHub-issue suljetaan",
      "trigger": {
        "component": "TRIGGER",
        "type": "jira.incoming.webhook",
        "value": {
          "searchOrProvide": "none",
          "jql": null
        }
      },
      "components": [
        {
          "component": "BRANCH",
          "type": "jira.issue.related",
          "value": {
            "relatedType": "jql",
            "jql": "project = US AND cf[10072] = {{webhookData.issue.number}} AND cf[10071] = \"{{webhookData.repository.name}}\"",
            "onlyUpdatedIssues": false
          },
          "children": [
            {
              "component": "ACTION",
              "type": "jira.issue.transition",
              "value": {
                "operations": [],
                "sendNotifications": false,
                "destinationStatus": {
                  "type": "NAME",
                  "value": "Done"
                }
              }
            }
          ]
        }
      ],
      "canOtherRuleTrigger": false,
      "notifyOnError": "FIRSTERROR",
      "projects": [],
      "labels": []
    },
    {
      "name": "Sääntö 4: GitHub issue reopened → Transition work item → To Do",
      "state": "ENABLED",
      "description": "Palauttaa Jira-tehtävän tilaksi To Do kun GitHub-issue avataan uudelleen",
      "trigger": {
        "component": "TRIGGER",
        "type": "jira.incoming.webhook",
        "value": {
          "searchOrProvide": "none",
          "jql": null
        }
      },
      "components": [
        {
          "component": "BRANCH",
          "type": "jira.issue.related",
          "value": {
            "relatedType": "jql",
            "jql": "project = US AND cf[10072] = {{webhookData.issue.number}} AND cf[10071] = \"{{webhookData.repository.name}}\"",
            "onlyUpdatedIssues": false
          },
          "children": [
            {
              "component": "ACTION",
              "type": "jira.issue.transition",
              "value": {
                "operations": [],
                "sendNotifications": false,
                "destinationStatus": {
                  "type": "NAME",
                  "value": "To Do"
                }
              }
            }
          ]
        }
      ],
      "canOtherRuleTrigger": false,
      "notifyOnError": "FIRSTERROR",
      "projects": [],
      "labels": []
    },
    {
      "name": "Sääntö 5a: GitHub issue labeled → Add Jira label",
      "state": "ENABLED",
      "description": "Lisää labelin Jira-tehtävään kun GitHubiin lisätään label",
      "trigger": {
        "component": "TRIGGER",
        "type": "jira.incoming.webhook",
        "value": {
          "searchOrProvide": "none",
          "jql": null
        }
      },
      "components": [
        {
          "component": "CONDITION",
          "type": "jira.comparator.condition",
          "value": {
            "first": "{{webhookData.action}}",
            "operator": "EQUALS",
            "second": "labeled"
          }
        },
        {
          "component": "BRANCH",
          "type": "jira.issue.related",
          "value": {
            "relatedType": "jql",
            "jql": "project = US AND cf[10072] = {{webhookData.issue.number}} AND cf[10071] = \"{{webhookData.repository.name}}\"",
            "onlyUpdatedIssues": false
          },
          "children": [
            {
              "component": "ACTION",
              "type": "jira.issue.edit",
              "value": {
                "operations": [
                  {
                    "field": {
                      "type": "ID",
                      "value": "labels"
                    },
                    "fieldType": "labels",
                    "type": "ADD",
                    "value": "{{webhookData.label.name}}"
                  }
                ],
                "sendNotifications": false
              }
            }
          ]
        }
      ],
      "canOtherRuleTrigger": false,
      "notifyOnError": "FIRSTERROR",
      "projects": [],
      "labels": []
    },
    {
      "name": "Sääntö 5b: GitHub issue unlabeled → Remove Jira label",
      "state": "ENABLED",
      "description": "Poistaa labelin Jira-tehtävästä kun GitHubista poistetaan label",
      "trigger": {
        "component": "TRIGGER",
        "type": "jira.incoming.webhook",
        "value": {
          "searchOrProvide": "none",
          "jql": null
        }
      },
      "components": [
        {
          "component": "CONDITION",
          "type": "jira.comparator.condition",
          "value": {
            "first": "{{webhookData.action}}",
            "operator": "EQUALS",
            "second": "unlabeled"
          }
        },
        {
          "component": "BRANCH",
          "type": "jira.issue.related",
          "value": {
            "relatedType": "jql",
            "jql": "project = US AND cf[10072] = {{webhookData.issue.number}} AND cf[10071] = \"{{webhookData.repository.name}}\"",
            "onlyUpdatedIssues": false
          },
          "children": [
            {
              "component": "ACTION",
              "type": "jira.issue.edit",
              "value": {
                "operations": [
                  {
                    "field": {
                      "type": "ID",
                      "value": "labels"
                    },
                    "fieldType": "labels",
                    "type": "REMOVE",
                    "value": "{{webhookData.label.name}}"
                  }
                ],
                "sendNotifications": false
              }
            }
          ]
        }
      ],
      "canOtherRuleTrigger": false,
      "notifyOnError": "FIRSTERROR",
      "projects": [],
      "labels": []
    },
    {
      "name": "Sääntö 8: GitHub issue comment created → Comment on work item",
      "state": "ENABLED",
      "description": "Lisää kommentin Jira-tehtävään kun GitHub-issueen lisätään kommentti",
      "trigger": {
        "component": "TRIGGER",
        "type": "jira.incoming.webhook",
        "value": {
          "searchOrProvide": "none",
          "jql": null
        }
      },
      "components": [
        {
          "component": "BRANCH",
          "type": "jira.issue.related",
          "value": {
            "relatedType": "jql",
            "jql": "project = US AND cf[10072] = {{webhookData.issue.number}} AND cf[10071] = \"{{webhookData.repository.name}}\"",
            "onlyUpdatedIssues": false
          },
          "children": [
            {
              "component": "ACTION",
              "type": "jira.issue.comment",
              "value": {
                "comment": "{{webhookData.comment.body}}",
                "sendNotifications": false
              }
            }
          ]
        }
      ],
      "canOtherRuleTrigger": false,
      "notifyOnError": "FIRSTERROR",
      "projects": [],
      "labels": []
    }
  ]
}
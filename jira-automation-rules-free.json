    {
      "name": "Sääntö 5: GitHub issue labeled/unlabeled → Edit work item labels",
      "state": "ENABLED",
      "canOtherRuleTrigger": false,
      "notifyOnError": "FIRSTERROR",
      "trigger": {
        "component": "TRIGGER",
        "type": "jira.incoming.webhook",
        "value": {
          "webhookType": "NO_ISSUES"
        }
      },
      "components": [
        {
          "component": "CONDITION",
          "type": "jira.condition.container.block",
          "value": null,
          "children": [
            {
              "component": "CONDITION_BLOCK",
              "type": "jira.condition.if.block",
              "value": {
                "conditionMatchType": "ALL"
              },
              "children": [
                {
                  "component": "CONDITION",
                  "type": "jira.comparator.condition",
                  "value": {
                    "first": "{{webhookData.action}}",
                    "operator": "REGEX_MATCHES",
                    "second": "^(labeled|unlabeled)$"
                  }
                },
                {
                  "component": "ACTION",
                  "type": "jira.lookup.issues",
                  "value": {
                    "query": {
                      "jql": "project = US AND cf[10072] = {{webhookData.issue.number}} AND cf[10071] = \"{{webhookData.repository.name}}\""
                    },
                    "variableName": "lookupIssues"
                  }
                },
                {
                  "component": "CONDITION",
                  "type": "jira.condition.container.block",
                  "value": null,
                  "children": [
                    {
                      "component": "CONDITION_BLOCK",
                      "type": "jira.condition.if.block",
                      "value": {
                        "conditionMatchType": "ALL"
                      },
                      "children": [
                        {
                          "component": "CONDITION",
                          "type": "jira.comparator.condition",
                          "value": {
                            "first": "{{lookupIssues.size}}",
                            "operator": "GREATER_THAN",
                            "second": "0"
                          }
                        },
                        {
                          "component": "ACTION",
                          "type": "jira.issue.edit",
                          "value": {
                            "issueKey": "{{lookupIssues.first.key}}",
                            "fields": {
                              "labels": {
                                "operation": "{{#if webhookData.action == 'labeled'}}add{{else}}remove{{/if}}",
                                "value": "{{webhookData.label.name}}"
                              }
                            }
                          }
                        },
                        {
                          "component": "CONDITION",
                          "type": "jira.condition.container.block",
                          "value": null,
                          "children": [
                            {
                              "component": "CONDITION_BLOCK",
                              "type": "jira.condition.if.block",
                              "value": {
                                "conditionMatchType": "ALL"
                              },
                              "children": [
                                {
                                  "component": "CONDITION",
                                  "type": "jira.comparator.condition",
                                  "value": {
                                    "first": "{{webhookData.label.name}}",
                                    "operator": "STARTS_WITH",
                                    "second": "priority:"
                                  }
                                },
                                {
                                  "component": "ACTION",
                                  "type": "jira.issue.edit",
                                  "value": {
                                    "issueKey": "{{lookupIssues.first.key}}",
                                    "fields": {
                                      "priority": {
                                        "name": "{{#if webhookData.label.name == 'priority:high'}}High{{else if webhookData.label.name == 'priority:medium'}}Medium{{else if webhookData.label.name == 'priority:low'}}Low{{else if webhookData.label.name == 'priority:lowest'}}Lowest{{/if}}"
                                      }
                                    }
                                  }
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ],
      "clientKey": "767fdf21-94ad-467a-bf3d-5890deb1f2ea",

{
  "cloud": true,
  "rules": [
    {
      "name": "Sääntö 1: GitHub issue opened → Luo Jira work item",
      "state": "ENABLED",
      "canOtherRuleTrigger": false,
      "notifyOnError": "FIRSTERROR",
      "trigger": {
        "component": "TRIGGER",
        "type": "jira.incoming.webhook",
        "value": {
          "webhookType": "NO_ISSUES"
        }
      },
      "components": [
        {
          "component": "ACTION",
          "type": "jira.lookup.issues",
          "value": {
            "query": {
              "jql": "project = US AND cf[10072] = {{webhookData.issue.number}} AND cf[10071] = \"{{webhookData.repository.name}}\""
            },
            "variableName": "lookupIssues"
          }
        },
        {
          "component": "CONDITION",
          "type": "jira.condition.container.block",
          "value": null,
          "children": [
            {
              "component": "CONDITION_BLOCK",
              "type": "jira.condition.if.block",
              "value": {
                "conditionMatchType": "ALL"
              },
              "children": [
                {
                  "component": "CONDITION",
                  "type": "jira.comparator.condition",
                  "value": {
                    "first": "{{lookupIssues.size}}",
                    "operator": "EQUALS",
                    "second": "0"
                  }
                },
                {
                  "component": "ACTION",
                  "type": "jira.issue.create",
                  "value": {
                    "project": "US",
                    "issuetype": "Story",
                    "fields": {
                      "summary": "Git: {{webhookData.issue.title}}",
                      "description": "{{webhookData.issue.body}}",
                      "customfield_10071": "{{webhookData.repository.name}}",
                      "customfield_10072": "{{webhookData.issue.number}}",
                      "customfield_10073": "{{webhookData.issue.html_url}}"
                    }
                  }
                }
              ]
            }
          ]
        }
      ],
      "clientKey": "767fdf21-94ad-467a-bf3d-5890deb1f2ea",
      "authorAccountId": "557058:18afcd39-a47a-4663-8b03-fcb7ce1003b8",
      "actor": {
        "type": "ACCOUNT_ID",
        "value": "557058:18afcd39-a47a-4663-8b03-fcb7ce1003b8"
      },
      "ruleScope": {
        "resources": [
          "ari:cloud:jira:38191fa4-e340-4d5e-8f7d-33c8f6829dbd:project/10000"
        ]
      },
      "ruleHome": {
        "ruleLifecycleHome": {
          "locationARI": "ari:cloud:jira:38191fa4-e340-4d5e-8f7d-33c8f6829dbd:project/10000"
